{
  "id": "com.iridium.communication",
  "name": "Communication",
  "version": "1.0.0",
  "author": "Iridium",
  "description": "Suggests mail and messaging apps for email addresses",
  "triggers": [
    {
      "signal": "clipboard.contentType",
      "matches": "email",
      "confidence": 0.90,
      "suggest": ["com.apple.mail", "com.google.Gmail", "ch.protonmail.desktop"]
    }
  ]
}
